#!/usr/bin/env bash

case "${1:-}" in
  -h|--help)
    cat <<'EOF'
fzfnpm — run any npm/yarn/pnpm script with fzf.

Usage: fzfnpm [option]

Run fzfnpm inside a project with a package.json, pick a script from the
list, and press <Enter> to run it with the detected package manager.
Your last script is bookmarked at the top for next time.

Options:
  -h, --help       show this help and exit
  -v, --version    print the version and exit
      --uninstall  remove fzfnpm and clear its cache
EOF
    exit 0
    ;;
  -v|--version)
    echo "version 0.12.0"
    exit 0
    ;;
  --uninstall)
    target="$(command -v fzfnpm 2>/dev/null || true)"
    if [ -n "$target" ]; then
      rm -f "$target" && echo "Removed $target"
    else
      echo "fzfnpm not found on PATH; nothing to remove."
    fi
    rm -f /tmp/fzfnpm_last_script_* 2>/dev/null || true
    echo "fzfnpm uninstalled 👋"
    exit 0
    ;;
  "")
    ;;
  -*)
    echo "Invalid option: $1" >&2
    echo "Try 'fzfnpm --help'." >&2
    exit 1
    ;;
esac

file="package.json"
if [ ! -e "$file" ]; then
    echo "No $file file 🫥"
	exit 1
fi

package="npm"
if [ -e "yarn.lock" ]; then
  package="yarn"
fi

if [ -e "pnpm-lock.yaml" ]; then
  package="pnpm"
fi

if [ -e "package-lock.json" ]; then
  package="npm"
fi

# Portable hash of the current directory (macOS has `md5`, Linux has `md5sum`)
function hash_cwd {
  if command -v md5sum >/dev/null 2>&1; then
    pwd | md5sum | cut -d' ' -f1
  elif command -v md5 >/dev/null 2>&1; then
    pwd | md5 -q
  else
    pwd | cksum | cut -d' ' -f1
  fi
}

# Get the last selected script from cache
last_script_file="/tmp/fzfnpm_last_script_$(hash_cwd)"
last_script=""
if [ -f "$last_script_file" ]; then
  last_script=$(cat "$last_script_file")
fi

function run_command {
  while read line; do
    [ -z "$line" ] && exit 0
    # Save the selected script for next time
    echo "$line" > "$last_script_file"

    case $package in
      pnpm)
        pnpm run "$line" < /dev/tty
        ;;
      yarn)
        yarn "$line" < /dev/tty
        ;;
      npm)
        npm run "$line" < /dev/tty
        ;;
      *)
        npm run "$line" < /dev/tty
        ;;
    esac
    exit $?
  done
  exit 0
}

# Bail out early if package.json has no scripts to run.
script_count="$(jq '.scripts // {} | length' package.json)"
if [ "${script_count:-0}" -eq 0 ]; then
  echo "No scripts in package.json 🫥"
  exit 1
fi

# Get scripts and reorder with last used at top
scripts=$(jq '.scripts | to_entries | .[] | .key' package.json | sed 's/"//g' | grep -E '^\w')

# Preview the real command each script runs (value of .scripts[name] in package.json).
# The jq filter is single-quoted so $k reaches jq (bound via --arg); fzf shell-quotes {}.
preview_cmd='jq -r --arg k {} '\''.scripts[$k] // empty'\'' package.json'

if [ -n "$last_script" ]; then
  # Put last script at the top, then the rest
  echo "$last_script"
  echo "$scripts" | grep -v "^$last_script$"
else
  echo "$scripts"
fi |
fzf --no-info --pointer=🚀 --prompt="🔥 [$package] " --header="Select script and hit <Enter> to run with $package" --preview "$preview_cmd" --preview-window=up:3:wrap |
run_command
exit 0
